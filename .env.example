# ============================================
# DESPERTAR ID™ — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el .env real a GitHub
# ============================================

# ─── Anthropic (Claude) ─────────────────────
# Obtén tu key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXX

# ─── ElevenLabs ─────────────────────────────
# Obtén tu key en: https://elevenlabs.io
# Voice ID: ve a My Voices y copia el ID de tu voz
ELEVENLABS_API_KEY=XXXXXXXXXX
ELEVENLABS_VOICE_ID=XXXXXXXXXX

# ─── PayPal ─────────────────────────────────
# Sandbox para pruebas: https://developer.paypal.com
# Production: https://www.paypal.com/businessprofile
PAYPAL_CLIENT_ID=XXXXXXXXXX
PAYPAL_SECRET=XXXXXXXXXX
PAYPAL_WEBHOOK_ID=XXXXXXXXXX
PAYPAL_ENV=sandbox
# Cambiar a "production" cuando lances

# ─── Resend (email) ──────────────────────────
# Obtén tu key en: https://resend.com
# Requiere verificar tu dominio
RESEND_API_KEY=re_XXXXXXXXXX

# ─── App ────────────────────────────────────
PORT=3000
FRONTEND_URL=https://tu-dominio.com
